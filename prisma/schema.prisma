generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model PriceHistory {
  id          Int       @id @default(autoincrement())
  currency    String
  rate        Decimal
  bid         Decimal? // Buy price (optional)
  ask         Decimal? // Sell price (optional)
  source      String
  timestamp   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  currencyRef Currency? @relation(fields: [currency], references: [code])

  @@index([currency, timestamp])
  @@index([timestamp])
  @@unique([currency, source, timestamp])
}

model Currency {
  code        String    @id  // e.g., "GHS", "KES"
  name        String      // Full name e.g., "Ghanaian Cedi"
  symbol      String      // Currency symbol e.g., "₵", "KES"
  decimals    Int       @default(2)           // Decimal places for display
  isActive    Boolean   @default(true)        // Whether this currency is currently supported
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  priceHistory PriceHistory[]
}

// On-Chain Confirmed Price Model
// Stores prices confirmed on Stellar via manageData or Soroban contract events
model OnChainPrice {
  id            Int       @id @default(autoincrement())
  currency      String    // e.g., "NGN", "KES", "GHS"
  rate          Decimal   // The confirmed price
  txHash        String    // Stellar transaction hash
  memoId        String?   // Memo ID from transaction (e.g., SF-NGN-1234567890-001)
  ledgerSeq     Int                          // Ledger sequence number
  confirmedAt   DateTime   // When transaction was confirmed on-chain

  @@index([currency, confirmedAt])
  @@index([txHash])
  @@index([ledgerSeq])
  @@unique([txHash, currency])

  createdAt     DateTime  @default(now())
}

model ProviderReputation {
  id              Int       @id @default(autoincrement())
  providerName    String  // e.g., "CoinGecko", "ExchangeRateAPI"
  endpoint        String?  // Specific endpoint URL or identifier
  status          String   // "online", "offline", "degraded"
  totalRequests   Int       @default(0)       // Total API calls made
  successfulRequests Int    @default(0)       // Successful responses
  failedRequests  Int       @default(0)       // Failed responses
  incorrectResponses Int   @default(0)        // Responses with invalid/incorrect data
  averageLatency  Float?    // Average response time in ms
  lastSuccess     DateTime?                    // Last successful response timestamp
  lastFailure     DateTime?                    // Last failed response timestamp
  lastIncorrect   DateTime?                    // Last incorrect response timestamp
  consecutiveFailures Int  @default(0)        // Current streak of consecutive failures
  consecutiveIncorrect Int @default(0)        // Current streak of consecutive incorrect responses
  
  // Reliability metrics
  reliabilityScore Float?   // Calculated score (0-100)
  lastUpdated     DateTime  @updatedAt
  
  createdAt       DateTime  @default(now())
  
  // Indexes for quick lookups
  @@index([providerName])
  @@index([status])
  @@index([reliabilityScore])
  @@unique([providerName, endpoint])
}

// Multi-Sig Price Approval Model
// Tracks price updates that require signatures from multiple oracle servers
model MultiSigPrice {
  id                Int       @id @default(autoincrement())
  priceReviewId     Int       // Reference to the price_review_records with contract_status tracking
  currency          String   // e.g., "NGN", "KES", "GHS"
  rate              Decimal   // The price to be updated
  source            String   // Price source (e.g., "CoinGecko")
  
  // Multi-sig status
  status            String   // "PENDING", "APPROVED", "REJECTED", "EXPIRED"
  requiredSignatures Int      @default(2)       // Number of signatures needed (typically 2)
  collectedSignatures Int     @default(0)       // Number of signatures collected so far
  
  // Stellar transaction details (set when fully signed)
  memoId            String?   // Memo ID from transaction
  stellarTxHash     String?   // Submitted transaction hash
  submittedAt       DateTime?                    // When transaction was submitted to Stellar
  
  // Timestamps
  requestedAt       DateTime  @default(now())   // When the multi-sig request was created
  expiresAt         DateTime                     // Expiration time for the signature request
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([currency, status, requestedAt])
  @@index([status, expiresAt])
  @@index([priceReviewId])

  multiSigSignatures MultiSigSignature[]
}

// Multi-Sig Signature Model
// Records individual signatures from oracle servers
model MultiSigSignature {
  id                Int       @id @default(autoincrement())
  multiSigPriceId   Int       // Reference to MultiSigPrice
  multiSigPrice     MultiSigPrice @relation(fields: [multiSigPriceId], references: [id], onDelete: Cascade)
  
  // Server/Signer information
  signerPublicKey   String    // Stellar public key of the signer
  signerName        String    // Human-readable name (e.g., "oracle-server-1")
  
  // Signature details
  signature         String    // The actual XDR signature (can be long)
  signedAt          DateTime  @default(now())   // When the signature was created
  
  createdAt         DateTime  @default(now())
  
  @@unique([multiSigPriceId, signerPublicKey])  // Prevent duplicate signatures from same signer
  @@index([multiSigPriceId])
  @@index([signerPublicKey])
}

// Error log table for tracking provider/fetcher failures
model ErrorLog {
  id           String   @id  // K-sortable KSUID (26-char Crockford Base32)
  providerName String   // e.g., "CoinGecko", "KESRateFetcher"
  errorMessage String?
  occurredAt   DateTime
  createdAt    DateTime  @default(now())

  @@index([providerName])
  @@index([occurredAt])
}

model RawData {
  id        Int      @id @default(autoincrement())
  currency  String
  provider  String
  endpoint  String?
  payload   String
  fetchedAt DateTime
  createdAt DateTime @default(now())

  @@index([currency, fetchedAt])
  @@index([provider, fetchedAt])
  @@index([createdAt])
}

model Relayer {
  id            Int      @id @default(autoincrement())
  name          String
  apiKey        String   @unique
  isActive      Boolean  @default(true)
  allowedAssets String
  whitelistedIps  String[]
  email           String?  @unique
  passwordHash    String?
  role            String?  @default("VIEWER")
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  permissionChanges PermissionChange[]
  sessions          UserSession[]
  registry          RelayerRegistry?
}

model RelayerRegistry {
  id               Int      @id @default(autoincrement())
  relayerId        Int      @unique
  relayer          Relayer  @relation(fields: [relayerId], references: [id], onDelete: Cascade)
  contactName      String
  email            String
  organizationName String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  key        String    @unique
  label      String?
  scopes     String[]
  ownerId    String?
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model UserSession {
  id           Int       @id @default(autoincrement())
  relayerId   Int
  relayer     Relayer   @relation(fields: [relayerId], references: [id])
  token       String    @unique
  ipAddress   String
  userAgent   String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  isActive    Boolean   @default(true)
}

model PermissionChange {
  id          Int       @id @default(autoincrement())
  relayerId  Int
  relayer    Relayer   @relation(fields: [relayerId], references: [id])
  changedBy  Int
  targetId   Int?
  field      String
  oldValue   String?
  newValue   String?
  reason     String?
  createdAt  DateTime  @default(now())
}

// OHLC Candle Model – Issue #208: Analytics | Time-Series Data Aggregation Service
// Stores Open/High/Low/Close aggregates produced by the PriceAggregator worker.
// Granularity is one of "MINUTE" | "HOUR" | "DAY".
model OhlcCandle {
  id          Int      @id @default(autoincrement())
  currency    String   // e.g., "NGN", "KES", "GHS"
  granularity String   // "MINUTE" | "HOUR" | "DAY"
  openTime    DateTime // Start of the candle window (UTC, truncated to granularity)
  closeTime   DateTime // End of the candle window (exclusive)

  open        Decimal  // First price in the window
  high        Decimal  // Highest price in the window
  low         Decimal  // Lowest price in the window
  close       Decimal  // Last price in the window
  count       Int      @default(0) // Number of raw ticks aggregated

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Composite unique – one candle per (currency, granularity, openTime)
  @@unique([currency, granularity, openTime])

  // Primary query pattern: fetch candles for a currency/granularity over a time range
  @@index([currency, granularity, openTime])
  // Secondary: sweep all candles in a time range (e.g. backfill checks)
  @@index([granularity, openTime])
}

// Hourly Statistics for smoothing out price spikes
model HourlyStats {
  id           Int      @id @default(autoincrement())
  currency     String
  averageRate  Decimal
  hour         DateTime // The start of the hour this average represents
  createdAt    DateTime  @default(now())

  @@unique([currency, hour])
  @@index([hour])
}

// Compliance Metadata Store for relayer performance auditing
// Tracks latency violations and other compliance events
model ComplianceMetadata {
  id                Int       @id @default(autoincrement())
  relayerId         Int?      // Optional link to the relayer (if known)
  relayerName       String?   // Relayer name at time of violation
  eventType         String    // e.g., "LATENCY_VIOLATION", "PAYLOAD_REJECTED"
  payloadTimestamp  DateTime? // Timestamp from the relayer payload
  receivedAt       DateTime  // When the payload was received
  latencyDiffMs     Int?      // Calculated latency difference in milliseconds
  thresholdMs       Int?      // The threshold that was exceeded
  details           String?   // Additional JSON details about the event
  resolved          Boolean   @default(false)  // Whether the violation has been addressed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([relayerId])
  @@index([eventType])
  @@index([createdAt])
  @@index([relayerName, createdAt])
}

// Pending Consensus Actions Table
// Stores sensitive system actions that require multi-admin approval before execution
model PendingConsensus {
  id                Int       @id @default(autoincrement())
  actionType        String    @db.VarChar(50)   // "HALT", "UPGRADE", "EMERGENCY_STOP"
  actionData        String?   @db.Text           // JSON data for the action (e.g., upgrade version, halt reason)
  status            String    @db.VarChar(20)    // "PENDING", "APPROVED", "REJECTED", "EXECUTED", "EXPIRED"
  requiredSignatures Int     @default(2)        // Number of admin signatures required
  collectedSignatures Int    @default(0)        // Number of signatures collected so far
  
  // Request information
  requestedBy       String    @db.VarChar(100)   // Admin who initiated the request
  requestedAt       DateTime  @default(now())    // When the request was created
  expiresAt         DateTime                     // When the request expires (if not approved)
  
  // Execution information
  executedAt        DateTime?                    // When the action was executed
  executionResult   String?   @db.Text          // Result of the execution (success/error message)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([actionType, status])
  @@index([status, expiresAt])
  @@index([requestedBy, requestedAt])

  pendingSignatures PendingSignature[]
}

// Pending Action Signatures Table
// Records admin signatures for pending consensus actions
model PendingSignature {
  id                    Int       @id @default(autoincrement())
  pendingConsensusId    Int       // Reference to PendingConsensus
  pendingConsensus      PendingConsensus @relation(fields: [pendingConsensusId], references: [id], onDelete: Cascade)
  
  // Admin information
  adminPublicKey        String    @db.VarChar(56)   // Stellar public key of the admin
  adminName             String    @db.VarChar(100)   // Human-readable admin name
  adminRole             String    @db.VarChar(50)    // Admin role (e.g., "SUPER_ADMIN", "OPERATOR")
  
  // Signature details
  signature             String    @db.Text          // Cryptographic signature
  ipAddress             String    @db.VarChar(45)    // IP address of the signer
  userAgent             String?   @db.VarChar(500)   // User agent of the signer
  signedAt              DateTime  @default(now())   // When the signature was provided
  
  createdAt             DateTime  @default(now())
  
  @@unique([pendingConsensusId, adminPublicKey])  // Prevent duplicate signatures from same admin
  @@index([pendingConsensusId])
  @@index([adminPublicKey])
}

// Audit Log Table for System Actions
// Comprehensive audit trail for all sensitive system operations
model AuditLog {
  id                    String    @id  // K-sortable KSUID (26-char Crockford Base32)
  eventType             String    @db.VarChar(50)    // e.g., "CONSENSUS_INITIATED", "CONSENSUS_APPROVED", "ACTION_EXECUTED"
  actionType            String?   @db.VarChar(50)    // The type of action being audited (e.g., "HALT", "UPGRADE")
  relatedId             Int?                         // ID of related record (e.g., PendingConsensus.id)
  
  // Actor information
  actorPublicKey        String    @db.VarChar(56)    // Public key of the actor
  actorName             String    @db.VarChar(100)    // Human-readable name
  actorRole             String?   @db.VarChar(50)    // Role of the actor
  
  // Event details
  eventDetails          String?   @db.Text           // JSON details about the event
  previousState         String?   @db.Text           // Previous state before this event
  newState              String?   @db.Text           // New state after this event
  
  // Request context
  ipAddress             String?   @db.VarChar(45)    // IP address of the request
  userAgent             String?   @db.VarChar(500)   // User agent of the request
  
  // Timestamps – TIMESTAMPTZ ensures UTC storage and retrieval
  occurredAt            DateTime  @db.Timestamptz(3) // When the event occurred (UTC)
  createdAt             DateTime  @default(now())    @db.Timestamptz(3) // When record was created (UTC)
  
  @@index([eventType, occurredAt])
  @@index([actionType, occurredAt])
  @@index([actorPublicKey, occurredAt])
  @@index([relatedId])
  @@index([occurredAt])
}

// Issuer Onboarding Request — Issue #120
// Healthcare providers submit an application to become an approved issuer.
// Admins approve/reject via the admin dashboard; approved issuers are added
// to the contract allowlist automatically.
model IssuerOnboardingRequest {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(200)   // Healthcare provider name
  licenseNumber   String    @db.VarChar(100)   // Professional license number
  country         String    @db.VarChar(100)   // Country of operation
  walletAddress   String    @db.VarChar(56)    // Stellar wallet address

  // Workflow status: PENDING → APPROVED | REJECTED
  status          String    @default("PENDING") @db.VarChar(20)

  // Admin decision
  reviewedBy      String?   @db.VarChar(100)   // Admin who reviewed the request
  reviewedAt      DateTime?                     // When the decision was made
  reviewNote      String?   @db.Text           // Optional note from admin

  // Contract allowlist tracking
  addedToAllowlist Boolean  @default(false)    // Whether the wallet was added on-chain
  allowlistTxHash  String?  @db.VarChar(100)   // Stellar tx hash for the allowlist update

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([walletAddress])
  @@index([createdAt])
}
